<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner categories:</p>
        <ul>
            <% if (typeof categories !== 'undefined' && categories && categories.length > 0) { %>
                <% categories.forEach((category) => { %>
                    <li>
                        <a href="/category/<%= category.category_id %>"><strong><%= category.category_id %></strong>: <%= category.name %></a>
                    </li>
                <% }) %>
            <% } else { %>
                <p>No Categories found.</p>
            <% } %>
        </ul>
    </main>
<%- include('partials/footer') %>
