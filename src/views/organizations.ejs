<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <p>Here are a few of our partner organizations:</p>

    <% if (typeof organizations !== 'undefined' && organizations && organizations.length > 0) { %>
        <ul>
            <% organizations.forEach((organization) => { %>
                <li>
                    <!-- <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <strong><%= organization.name %></strong>: <%= organization.contact_email %> -->

                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo"><a
                        href="/organizations/<%= organization.organization_id %>">
                        <%= organization.name %>
                    </a>: <%= organization.contact_email %>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No organizations found.</p>
    <% } %>
</main>
<%- include('partials/footer') %>