<%- include('partials/header') %>
<main>
    <h1>
        <%= title %>
    </h1>
    <h2>Upcoming and ongoing Service Projects</h2>
    <% if (typeof projects !== 'undefined' && projects && projects.length > 0) { %>
        <ul>
            <% projects.forEach((project) => { %>
                <li>
                    Date: <%= new Date(project.project_date).toLocaleDateString('en-US') %>: <strong><%= project.title %></strong> (<%= project.organization_name %>)
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>No Projects found.</p>
    <% } %>
</main>
<%- include('partials/footer') %>